{
  "name": "rbac-frontend-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "prepare": "husky",
    "format-code:staged": "prettier --write",
    "check-html-formatting:staged": "prettier --check",
    "lint:fix": "eslint --fix",
    "storybook": "ng run rbac_frontend_angular:storybook",
    "build-storybook": "ng run rbac_frontend_angular:build-storybook"
  },
  "lint-staged": {
    "*.html": [
      "npm run format-code:staged",
      "npm run check-html-formatting:staged"
    ],
    "*.js|*.ts": [
      "npm run format-code:staged",
      "npm run lint:fix"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.0.6",
    "@angular/cdk": "^19.0.5",
    "@angular/common": "^19.0.6",
    "@angular/compiler": "^19.0.6",
    "@angular/core": "^19.0.6",
    "@angular/forms": "^19.0.6",
    "@angular/platform-browser": "^19.0.6",
    "@angular/platform-browser-dynamic": "^19.0.6",
    "@angular/router": "^19.0.6",
    "@ctrl/tinycolor": "^4.1.0",
    "angular-svg-icon": "^19.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "echarts": "^5.5.1",
    "lodash": "^4.17.21",
    "ng-zorro-antd": "^19.0.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.7",
    "@angular-eslint/schematics": "^19.0.2",
    "@angular/cli": "^19.0.7",
    "@angular/compiler-cli": "^19.0.6",
    "@chromatic-com/storybook": "^1.9.0",
    "@compodoc/compodoc": "^1.1.26",
    "@storybook/addon-docs": "^8.3.6",
    "@storybook/addon-essentials": "^8.3.6",
    "@storybook/addon-interactions": "^8.3.6",
    "@storybook/addon-links": "^8.3.6",
    "@storybook/addon-onboarding": "^8.3.6",
    "@storybook/angular": "^8.3.6",
    "@storybook/blocks": "^8.3.6",
    "@storybook/test": "^8.3.6",
    "@types/jasmine": "~5.1.0",
    "@types/lodash": "^4.17.15",
    "@types/node": "^22.13.13",
    "angular-eslint": "18.4.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-storybook": "^0.10.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "husky": "^9.1.6",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.3.3",
    "prettier-eslint": "^16.3.0",
    "storybook": "^8.3.6",
    "typescript": "~5.5.2",
    "typescript-eslint": "8.10.0"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
